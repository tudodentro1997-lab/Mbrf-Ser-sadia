datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              Int       @id @default(autoincrement())
  name            String
  cpf             String    @unique
  email           String    @unique
  password        String
  phone           String?
  role            String    @default("NAO_SOCIO") // "ADMIN", "SOCIO", "NAO_SOCIO"
  matricula       String?   @unique // Apenas para sócios
  status          String    @default("ACTIVE") // "ACTIVE", "INACTIVE"
  financialStatus String    @default("EM_DIA") // "EM_DIA", "EM_ATRASO"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  bookings        Booking[]
}

model Space {
  id            Int       @id @default(autoincrement())
  name          String
  description   String
  capacity      Int
  rules         String?
  priceSocio    Float
  priceNaoSocio Float
  imageUrls     String    @default("[]") // Lista de URLs em formato JSON string
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
}

model Booking {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId       Int
  space         Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  date          String // Formato YYYY-MM-DD
  startTime     String // Formato HH:MM
  endTime       String // Formato HH:MM
  totalAmount   Float
  userType      String // "SOCIO" ou "NAO_SOCIO" no momento da reserva
  status        String   @default("PENDENTE") // "PENDENTE", "AGUARDANDO_PAGAMENTO", "CONFIRMADA", "CANCELADA", "EXPIRADA"
  paymentMethod String? // "PIX", "STRIPE", "MERCADO_PAGO"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
